// Edusoftnet Clone — Prisma schema
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// ============================================================
/// AUTH / USERS / ROLES
/// ============================================================

enum Role {
  ADMIN
  DIRECTION
  TEACHER
  PARENT
  STUDENT
  PSYCHOLOGY
  TREASURY
  GATEKEEPER
  SECRETARY
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String?  @unique
  passwordHash String
  firstName    String
  lastName     String
  dni          String?  @unique
  phone        String?
  avatarUrl    String?
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student         Student?
  parent          Parent?
  teacher         Teacher?
  staff           Staff?
  sessions        Session[]
  sentMessages    ChatMessage[]     @relation("SentMessages")
  receivedThreads ChatParticipant[]
  notifications   Notification[]
  uploadedFiles   DriveFile[]       @relation("UploadedBy")
  documents       Document[]        @relation("DocOwner")
  ticketsCreated  Ticket[]          @relation("TicketCreator")
  ticketsAssigned Ticket[]          @relation("TicketAssignee")
  gateLogs        GateLog[]
  auditLogs       AuditLog[]
  announcements   Announcement[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// ============================================================
/// ESTRUCTURA ACADÉMICA
/// ============================================================

model SchoolYear {
  id        String   @id @default(cuid())
  year      Int      @unique
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
  periods   Period[]
  grades    Grade[]
  createdAt DateTime @default(now())
}

/// Bimestre / Trimestre
model Period {
  id              String                 @id @default(cuid())
  schoolYearId    String
  name            String
  ordinal         Int
  startDate       DateTime
  endDate         DateTime
  schoolYear      SchoolYear             @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  scores          Score[]
  finalScores     FinalScore[]
  gradingWindows  GradingWindow[]
  competencyAssessments CompetencyAssessment[]

  @@index([schoolYearId])
}

/// Ventana de captura de notas controlada por administración.
/// Determina cuándo los docentes pueden registrar/editar notas.
model GradingWindow {
  id        String              @id @default(cuid())
  periodId  String
  name      String              // "Captura mes de mayo", "Notas del I Bimestre", etc.
  opensAt   DateTime
  closesAt  DateTime
  /// Alcance: GLOBAL aplica a todos. LEVEL/GRADE/SECTION/COURSE filtran.
  scope     GradingWindowScope  @default(GLOBAL)
  level     EducationLevel?
  gradeId   String?
  sectionId String?
  courseId  String?
  /// AUTO = abierto si hoy está entre opensAt y closesAt
  /// FORCE_OPEN = abierto manualmente aunque la fecha haya pasado
  /// FORCE_CLOSED = cerrado manualmente aunque la fecha esté vigente
  state     GradingWindowState  @default(AUTO)
  notes     String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  period    Period              @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@index([periodId])
  @@index([opensAt, closesAt])
}

enum GradingWindowScope {
  GLOBAL
  LEVEL
  GRADE
  SECTION
  COURSE
}

enum GradingWindowState {
  AUTO
  FORCE_OPEN
  FORCE_CLOSED
}

enum EducationLevel {
  INICIAL
  PRIMARIA
  SECUNDARIA
}

model Grade {
  id           String         @id @default(cuid())
  schoolYearId String
  level        EducationLevel
  ordinal      Int
  name         String
  schoolYear   SchoolYear     @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  sections     Section[]

  @@unique([schoolYearId, level, ordinal])
}

model Section {
  id                String             @id @default(cuid())
  gradeId           String
  name              String
  capacity          Int                @default(30)
  tutorId           String?
  grade             Grade              @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  tutor             Teacher?           @relation("SectionTutor", fields: [tutorId], references: [id])
  enrollments       Enrollment[]
  courseAssignments CourseAssignment[]
  attendance        AttendanceRecord[]
  announcements     Announcement[]

  @@index([gradeId])
}

model Course {
  id           String             @id @default(cuid())
  code         String             @unique
  name         String
  level        EducationLevel
  description  String?
  hoursPerWeek Int                @default(2)
  competencies Competency[]
  assignments  CourseAssignment[]
}

model Competency {
  id           String                 @id @default(cuid())
  courseId     String
  code         String
  name         String
  course       Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  capabilities Capability[]
  assessments  CompetencyAssessment[]
}

/// Evaluación MINEDU por competencia, por trimestre.
/// 3 sub-evaluaciones mensuales (m1, m2, m3) más una conclusión trimestral.
/// letterGrade puede ser AD, A, B, C.
model CompetencyAssessment {
  id                 String           @id @default(cuid())
  studentId          String
  courseAssignmentId String
  competencyId       String
  periodId           String
  m1                 String?          // letra del mes 1 del trimestre
  m2                 String?          // letra del mes 2
  m3                 String?          // letra del mes 3
  letterGrade        String?          // calificación trimestral (auto o manual)
  observation        String?
  updatedAt          DateTime         @updatedAt
  student            Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseAssignment   CourseAssignment @relation(fields: [courseAssignmentId], references: [id], onDelete: Cascade)
  competency         Competency       @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  period             Period           @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([studentId, competencyId, periodId])
  @@index([courseAssignmentId, periodId])
}

model Capability {
  id           String                 @id @default(cuid())
  competencyId String
  code         String
  name         String
  competency   Competency             @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  indicators   PerformanceIndicator[]
}

model PerformanceIndicator {
  id           String     @id @default(cuid())
  capabilityId String
  description  String
  weight       Float      @default(1.0)
  capability   Capability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)
  scores       Score[]
}

/// Asignación docente-curso-sección
model CourseAssignment {
  id                    String                 @id @default(cuid())
  courseId              String
  sectionId             String
  teacherId             String
  course                Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  section               Section                @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  teacher               Teacher                @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  assignments           Assignment[]
  schedules             ScheduleSlot[]
  scores                Score[]
  finalScores           FinalScore[]
  lessons               LessonSession[]
  competencyAssessments CompetencyAssessment[]

  @@unique([courseId, sectionId, teacherId])
}

model ScheduleSlot {
  id                 String           @id @default(cuid())
  courseAssignmentId String
  weekday            Int
  startTime          String
  endTime            String
  classroom          String?
  courseAssignment   CourseAssignment @relation(fields: [courseAssignmentId], references: [id], onDelete: Cascade)
}

/// ============================================================
/// PERSONAS
/// ============================================================

model Student {
  id               String               @id @default(cuid())
  userId           String               @unique
  studentCode      String               @unique
  birthDate        DateTime
  gender           String?
  address          String?
  bloodType        String?
  emergencyContact String?
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments      Enrollment[]
  parents          ParentStudent[]
  scores           Score[]
  finalScores      FinalScore[]
  attendance       AttendanceRecord[]
  submissions      Submission[]
  workshops        WorkshopEnrollment[]
  readings         ReadingProgress[]
  psychCases       PsychologyCase[]
  healthRecords    HealthRecord[]
  vaccinations     Vaccination[]
  lifeRecord       StudentLifeEntry[]
  payments         Payment[]
  invoices         Invoice[]
  competencyAssessments CompetencyAssessment[]
}

model Enrollment {
  id           String   @id @default(cuid())
  studentId    String
  sectionId    String
  schoolYearId String
  enrolledAt   DateTime @default(now())
  status       String   @default("ACTIVE")
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  section      Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([studentId, schoolYearId])
}

model Parent {
  id           String          @id @default(cuid())
  userId       String          @unique
  occupation   String?
  workplace    String?
  relationship String?
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  children     ParentStudent[]
  interviews   Interview[]
  prospects    Prospect[]
}

model ParentStudent {
  parentId  String
  studentId String
  isPrimary Boolean @default(false)
  parent    Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([parentId, studentId])
}

model Teacher {
  id              String             @id @default(cuid())
  userId          String             @unique
  employeeCode    String             @unique
  hiredAt         DateTime?
  speciality      String?
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments     CourseAssignment[]
  tutorOf         Section[]          @relation("SectionTutor")
  workshops       Workshop[]
  interviews      Interview[]
  curriculumPlans CurriculumPlan[]
}

model Staff {
  id           String  @id @default(cuid())
  userId       String  @unique
  employeeCode String  @unique
  position     String
  department   String?
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// ============================================================
/// CALIFICACIONES
/// ============================================================

model Score {
  id                 String                @id @default(cuid())
  studentId          String
  courseAssignmentId String
  indicatorId        String?
  periodId           String
  value              Float
  letterGrade        String?
  comment            String?
  evaluatedAt        DateTime              @default(now())
  student            Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseAssignment   CourseAssignment      @relation(fields: [courseAssignmentId], references: [id], onDelete: Cascade)
  indicator          PerformanceIndicator? @relation(fields: [indicatorId], references: [id])
  period             Period                @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@index([studentId, periodId])
}

model FinalScore {
  id                 String           @id @default(cuid())
  studentId          String
  courseAssignmentId String
  periodId           String
  value              Float
  letterGrade        String
  observation        String?
  student            Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseAssignment   CourseAssignment @relation(fields: [courseAssignmentId], references: [id], onDelete: Cascade)
  period             Period           @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseAssignmentId, periodId])
}

/// ============================================================
/// ASISTENCIA (onTime)
/// ============================================================

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
  EARLY_LEAVE
}

model AttendanceRecord {
  id        String           @id @default(cuid())
  studentId String
  sectionId String
  date      DateTime
  status    AttendanceStatus
  arrivedAt DateTime?
  remark    String?
  markedBy  String?
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  section   Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([sectionId, date])
}

/// ============================================================
/// ECLASS — Tareas, Submissions, Lecciones
/// ============================================================

enum AssignmentType {
  HOMEWORK
  PROJECT
  QUIZ
  EXAM
  PRACTICE
  FORUM
}

model Assignment {
  id                 String           @id @default(cuid())
  courseAssignmentId String
  title              String
  description        String?
  type               AssignmentType   @default(HOMEWORK)
  maxScore           Float            @default(20)
  dueDate            DateTime
  publishedAt        DateTime         @default(now())
  rubricJson         String?
  attachmentsJson    String?
  courseAssignment   CourseAssignment @relation(fields: [courseAssignmentId], references: [id], onDelete: Cascade)
  submissions        Submission[]

  @@index([courseAssignmentId])
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  LATE
  GRADED
  RETURNED
}

model Submission {
  id           String           @id @default(cuid())
  assignmentId String
  studentId    String
  content      String?
  fileUrl      String?
  status       SubmissionStatus @default(PENDING)
  submittedAt  DateTime?
  score        Float?
  feedback     String?
  gradedAt     DateTime?
  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
}

model LessonSession {
  id                 String           @id @default(cuid())
  courseAssignmentId String
  date               DateTime
  topic              String
  description        String?
  materialsJson      String?
  recordingUrl       String?
  courseAssignment   CourseAssignment @relation(fields: [courseAssignmentId], references: [id], onDelete: Cascade)
}

/// ============================================================
/// CURRÍCULO (emonitor)
/// ============================================================

enum PlanType {
  ANNUAL
  UNIT
  SESSION
}

model CurriculumPlan {
  id          String   @id @default(cuid())
  teacherId   String
  type        PlanType
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  contentJson String?
  status      String   @default("DRAFT")
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
}

/// ============================================================
/// MENSAJERÍA (echat)
/// ============================================================

model ChatThread {
  id           String            @id @default(cuid())
  title        String?
  isGroup      Boolean           @default(false)
  createdAt    DateTime          @default(now())
  participants ChatParticipant[]
  messages     ChatMessage[]
}

model ChatParticipant {
  threadId String
  userId   String
  joinedAt DateTime   @default(now())
  thread   ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([threadId, userId])
}

model ChatMessage {
  id            String     @id @default(cuid())
  threadId      String
  senderId      String
  body          String
  attachmentUrl String?
  createdAt     DateTime   @default(now())
  readAt        DateTime?
  thread        ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender        User       @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  body        String
  authorId    String
  audience    String
  sectionId   String?
  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
  pinned      Boolean   @default(false)
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  section     Section?  @relation(fields: [sectionId], references: [id])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

/// ============================================================
/// EFAMILY — Admisión / CRM
/// ============================================================

enum ProspectStage {
  LEAD
  CONTACTED
  INTERVIEW
  EVALUATION
  PRE_ENROLLMENT
  ENROLLED
  REJECTED
}

model Prospect {
  id             String        @id @default(cuid())
  parentId       String?
  childName      String
  childBirthDate DateTime
  desiredGrade   String
  contactPhone   String
  contactEmail   String?
  source         String?
  stage          ProspectStage @default(LEAD)
  notes          String?
  createdAt      DateTime      @default(now())
  parent         Parent?       @relation(fields: [parentId], references: [id])
}

/// ============================================================
/// TESORERÍA
/// ============================================================

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELED
}

model Invoice {
  id           String        @id @default(cuid())
  number       String        @unique
  studentId    String
  concept      String
  amount       Float
  dueDate      DateTime
  status       InvoiceStatus @default(PENDING)
  issuedAt     DateTime      @default(now())
  sunatCode    String?
  documentType String        @default("BOLETA")
  student      Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments     Payment[]
}

model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  studentId String
  amount    Float
  method    String
  reference String?
  paidAt    DateTime @default(now())
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

/// ============================================================
/// ELIBRARY — Plan lector
/// ============================================================

model Book {
  id          String            @id @default(cuid())
  isbn        String?           @unique
  title       String
  author      String
  publisher   String?
  level       EducationLevel
  coverUrl    String?
  description String?
  readings    ReadingProgress[]
}

enum ReadingState {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  EVALUATED
}

model ReadingProgress {
  id               String       @id @default(cuid())
  studentId        String
  bookId           String
  state            ReadingState @default(ASSIGNED)
  progress         Int          @default(0)
  literalScore     Float?
  inferentialScore Float?
  criticalScore    Float?
  completedAt      DateTime?
  student          Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  book             Book         @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([studentId, bookId])
}

/// ============================================================
/// ECARE — Psicología
/// ============================================================

enum CaseStatus {
  OPEN
  IN_FOLLOWUP
  CLOSED
}

model PsychologyCase {
  id          String     @id @default(cuid())
  studentId   String
  title       String
  description String
  status      CaseStatus @default(OPEN)
  openedAt    DateTime   @default(now())
  closedAt    DateTime?
  notesJson   String?
  student     Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model PsychologicalTest {
  id         String   @id @default(cuid())
  studentId  String
  testType   String
  resultJson String
  takenAt    DateTime @default(now())
}

/// ============================================================
/// SALUD / ENFERMERÍA
/// ============================================================

model HealthRecord {
  id         String   @id @default(cuid())
  studentId  String
  date       DateTime @default(now())
  symptoms   String
  treatment  String?
  attendedBy String?
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Vaccination {
  id          String    @id @default(cuid())
  studentId   String
  vaccineName String
  dose        String
  appliedAt   DateTime
  nextDose    DateTime?
  notes       String?
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

/// ============================================================
/// VIDA ESTUDIANTIL / FORMATIVO
/// ============================================================

enum LifeEntryType {
  ACHIEVEMENT
  INCIDENT
  COMMENT
  RECOGNITION
  CONDUCT
}

model StudentLifeEntry {
  id        String        @id @default(cuid())
  studentId String
  type      LifeEntryType
  title     String
  body      String
  date      DateTime      @default(now())
  authorId  String?
  student   Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

/// ============================================================
/// TALLERES (extracurriculares)
/// ============================================================

model Workshop {
  id          String               @id @default(cuid())
  name        String
  description String?
  teacherId   String?
  schedule    String?
  capacity    Int                  @default(20)
  level       EducationLevel?
  teacher     Teacher?             @relation(fields: [teacherId], references: [id])
  enrollments WorkshopEnrollment[]
}

model WorkshopEnrollment {
  id         String   @id @default(cuid())
  workshopId String
  studentId  String
  enrolledAt DateTime @default(now())
  workshop   Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([workshopId, studentId])
}

/// ============================================================
/// EDOCUMENTS / EDRIVE
/// ============================================================

model Document {
  id         String    @id @default(cuid())
  ownerId    String
  title      String
  category   String
  version    Int       @default(1)
  fileUrl    String?
  signedAt   DateTime?
  signedById String?
  createdAt  DateTime  @default(now())
  owner      User      @relation("DocOwner", fields: [ownerId], references: [id], onDelete: Cascade)
}

model DriveFile {
  id         String   @id @default(cuid())
  uploaderId String
  filename   String
  mimeType   String
  sizeBytes  Int
  path       String
  folder     String?
  isShared   Boolean  @default(false)
  uploadedAt DateTime @default(now())
  uploader   User     @relation("UploadedBy", fields: [uploaderId], references: [id], onDelete: Cascade)
}

/// ============================================================
/// MESA DE PARTES
/// ============================================================

enum TicketStatus {
  OPEN
  IN_REVIEW
  ANSWERED
  CLOSED
  REJECTED
}

model Ticket {
  id         String       @id @default(cuid())
  number     String       @unique
  subject    String
  body       String
  status     TicketStatus @default(OPEN)
  category   String
  creatorId  String
  assigneeId String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  creator    User         @relation("TicketCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  assignee   User?        @relation("TicketAssignee", fields: [assigneeId], references: [id])
}

/// ============================================================
/// PORTERÍA
/// ============================================================

enum GateDirection {
  IN
  OUT
}

model GateLog {
  id         String        @id @default(cuid())
  userId     String
  direction  GateDirection
  occurredAt DateTime      @default(now())
  reason     String?
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// ============================================================
/// ENTREVISTAS
/// ============================================================

enum InterviewMode {
  IN_PERSON
  VIRTUAL
}

enum InterviewStatus {
  REQUESTED
  CONFIRMED
  COMPLETED
  CANCELED
}

model Interview {
  id             String          @id @default(cuid())
  teacherId      String
  parentId       String
  scheduledAt    DateTime
  durationMin    Int             @default(30)
  mode           InterviewMode   @default(IN_PERSON)
  status         InterviewStatus @default(REQUESTED)
  topic          String
  meetingUrl     String?
  notes          String?
  agreementsJson String?
  teacher        Teacher         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  parent         Parent          @relation(fields: [parentId], references: [id], onDelete: Cascade)
}

/// ============================================================
/// ACTIVOS FIJOS
/// ============================================================

model FixedAsset {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  category    String
  location    String?
  purchasedAt DateTime?
  cost        Float?
  status      String    @default("ACTIVE")
}

/// ============================================================
/// AUDITORÍA
/// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metaJson  String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
}
